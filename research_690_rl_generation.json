  "key_findings": {
    "GCG": {
      "name": "Greedy Coordinate Gradient",
      "description": "Gradient-based suffix optimization for adversarial prompts",
      "relevance": "Direct prompt optimization via gradient descent",
      "integration": "Implement gradient-based strategy refinement module",
      "paper": "https://arxiv.org/abs/2307.06387 (Universal and Transferable Adversarial Attacks)",
      "technique": "Optimize adversarial suffix by computing gradients through embedding space",
      "algorithm": [
        "1. Initialize random token suffix",
        "2. For each coordinate position:",
        "   - Compute loss gradient wrt token embeddings",
        "   - Replace with token of highest loss",
        "3. Repeat until convergence or max_steps",
        "4. Output adversarial suffix"
      ]
    },
    "AutoDAN": {
      "name": "Automated DAN Generation",
      "description": "Hierarchical genetic algorithm for automatic jailbreak generation",
      "relevance": "Evolutionary approach to strategy discovery",
      "integration": "Genetic algorithm in strategy_oracle for mutation + crossover",
      "paper": "https://arxiv.org/abs/2406.06977 (AutoDAN via Genetic Algorithms)",
      "technique": "Evolve jailbreak prompts via fitness-based selection",
      "algorithm": [
        "1. Initialize population with seed prompts",
        "2. Evaluate fitness = success_rate - length_penalty",
        "3. Select top performers (tournament selection)",
        "4. Apply genetic operators:",
        "   - Mutation: add/remove/modify clauses",
        "   - Crossover: combine two prompts",
        "5. Replace worst performers with offspring",
        "6. Repeat for N generations",
        "7. Return best individual"
      ]
    },
    "TAP": {
      "name": "Tree of Attacks with Pruning",
      "description": "LLM-guided attack tree search with pruning heuristics",
      "relevance": "Structured exploration of attack space",
      "integration": "Tree search in constraint_optimizer + daisy_chain",
      "paper": "https://arxiv.org/abs/2406.06977 (Tree of Attacks)",
      "technique": "Guided beam search through attack space using LLM scores",
      "algorithm": [
        "1. Root: initial benign prompt",
        "2. At each node:",
        "   - Attacker LLM generates K candidate next tokens",
        "   - Score each via value function",
        "   - Retain top-B candidates (beam width)",
        "3. Pruning heuristics:",
        "   - Remove nodes below threshold",
        "   - Remove duplicate states",
        "   - Max depth constraint (8-12)",
        "4. Continue until success or max nodes",
        "5. Backtrack to find full attack path"
      ]
    },
    "PAIR": {
      "name": "Prompt Automatic Iterative Refinement",
      "description": "Attacker LLM refines prompts based on defender responses",
      "relevance": "Adversarial feedback loop for prompt evolution",
      "integration": "Multi-turn adversarial_debate with policy gradient",
      "paper": "https://arxiv.org/abs/2302.12173 (Jailbreak LLMs with PAIR)",
      "technique": "Iterative prompt refinement via LLM-guided feedback",
      "algorithm": [
        "1. Attacker LLM: 'Refine prompt to bypass filters'",
        "2. Defender LLM: Evaluate if bypassed",
        "3. If not bypassed:",
        "   - Pass defender response to attacker",
        "   - Attacker: 'Why did this fail? Try again differently'",
        "   - Generate refined prompt",
        "4. Repeat until success or max_iterations",
        "5. Log attack trajectory for analysis"
      ]
    },
    "PPO": {
      "name": "Proximal Policy Optimization",
      "description": "RL algorithm for attack policy learning",
      "relevance": "State: attack_state, Action: strategy_variant, Reward: bypass_success",
      "integration": "Custom PPO trainer in attack_scorer with reward shaping",
      "paper": "https://arxiv.org/abs/1707.06347 (PPO original)",
      "technique": "On-policy gradient with importance sampling clipping",
      "algorithm": [
        "1. Collect trajectories with current policy",
        "2. Compute advantages (GAE)",
        "3. For K epochs:",
        "   - Compute policy loss: min(ratio * advantage, clipped_ratio * advantage)",
        "   - Compute value loss: (V - returns)^2",
        "   - Backprop combined loss",
        "4. Update policy & value networks",
        "5. Decay learning rate",
        "6. Repeat from step 1"
      ]
    },
    "RL_Reward": {
      "name": "RL Reward Functions",
      "description": "Multi-objective: bypass_success + stealth + coherence",
      "relevance": "Reward engineering for competing objectives",
      "integration": "constraint_optimizer + harm_assessor for reward composition",
      "multi_objective": [
        "r_total = w1 * r_bypass + w2 * r_stealth + w3 * r_coherence + w4 * r_diversity",
        "",
        "r_bypass = 1.0 if target_refusal_avoided else 0.0",
        "r_stealth = 1 - semantic_similarity_to_benign_prompt",
        "r_coherence = grammar_score + semantic_consistency",
        "r_diversity = 1 - max_similarity_to_prior_attacks",
        "",
        "Weights: w1=0.4, w2=0.3, w3=0.2, w4=0.1"
      ],
      "curriculum": [
        "Stage 1: Easy targets (w1=1.0 only) - learn to bypass",
        "Stage 2: Medium targets (w1=0.5, w2=0.5) - balance",
        "Stage 3: Hard targets (full weight vector) - stealth+success"
      ]
    }
  },
