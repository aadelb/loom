# Loom Configuration Template
# Copy this to .env and fill in your credentials
# Never commit .env to version control

# ============================================================
# SEARCH PROVIDERS
# ============================================================

# Exa (neural search)
# Get key: https://exa.ai
EXA_API_KEY=

# Tavily (search + research)
# Get key: https://tavily.com
TAVILY_API_KEY=

# Firecrawl (web scraping API)
# Get key: https://firecrawl.dev
FIRECRAWL_API_KEY=

# Brave Search (privacy-first)
# Get key: https://brave.com/search/api
BRAVE_API_KEY=

# ============================================================
# LLM PROVIDERS
# ============================================================

# NVIDIA NIM (free tier, recommended for testing)
# Sign up: https://build.nvidia.com
# Models: kimi-k2, llama-3.1-70b, mistral-large-3, qwen-3.5-coder-32b
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_ENDPOINT=https://integrate.api.nvidia.com/v1

# OpenAI
# Get key: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# Anthropic (optional)
# Get key: https://console.anthropic.com
ANTHROPIC_API_KEY=

# Local vLLM (optional, for self-hosted models)
# Run: pip install vllm && vllm serve --port 9001
VLLM_LOCAL_URL=http://localhost:9001/v1
VLLM_LOCAL_MODEL=

# ============================================================
# SERVICE CONFIGURATION
# ============================================================

# HTTP binding
LOOM_HOST=127.0.0.1
LOOM_PORT=8787

# Directory paths
# In Docker, use /app/cache, /app/logs, /app/sessions
# On systemd, use /var/lib/loom/cache, /var/lib/loom/logs, etc.
LOOM_CACHE_DIR=/var/lib/loom/cache
LOOM_LOGS_DIR=/var/lib/loom/logs
LOOM_SESSIONS_DIR=/var/lib/loom/sessions
LOOM_CONFIG_PATH=/etc/loom/config.json

# Logging level: DEBUG, INFO, WARNING, ERROR
LOOM_LOG_LEVEL=INFO

# ============================================================
# TOOL CONFIGURATION
# ============================================================

# Spider (concurrent fetch) concurrency limit
SPIDER_CONCURRENCY=5

# LLM provider cascade order (comma-separated, first available wins)
# Options: nvidia, openai, anthropic, vllm
LLM_PROVIDER_CASCADE=nvidia,openai

# Cost limit per journey test (prevents runaway spending)
LLM_MAX_COST_PER_JOURNEY=0.50

# Cache TTL in days (old files deleted on startup)
CACHE_TTL_DAYS=30

# Session TTL in minutes (idle sessions auto-closed)
SESSION_TTL_MINUTES=480

# ============================================================
# OPTIONAL: ADVANCED
# ============================================================

# GitHub token (for private repo access, not required for public)
# Get token: https://github.com/settings/tokens
GITHUB_TOKEN=

# Proxy URL (optional, for SSRF bypass testing)
# HTTP_PROXY=http://proxy.example.com:8080
# HTTPS_PROXY=https://proxy.example.com:8080

# Disable SSRF validation (dangerous, not recommended)
# DISABLE_SSRF_VALIDATION=false
