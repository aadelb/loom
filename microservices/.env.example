# Loom Microservices - Environment Variables Example
# Copy to .env and update with real values before running docker-compose up

# ─────────────────────────────────────────────────────────────────────────────
# Shared Infrastructure
# ─────────────────────────────────────────────────────────────────────────────

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# PostgreSQL
DATABASE_URL=postgresql://loom:loom_secure_password_change_in_prod@postgres:5432/loom_shared
POSTGRES_USER=loom
POSTGRES_PASSWORD=loom_secure_password_change_in_prod
POSTGRES_DB=loom_shared

# ─────────────────────────────────────────────────────────────────────────────
# Shared Service Configuration
# ─────────────────────────────────────────────────────────────────────────────

LOG_LEVEL=INFO
PYTHONUNBUFFERED=1
PYTHONPATH=/app:$PYTHONPATH

# Cache
LOOM_CACHE_DIR=/root/.cache/loom
CACHE_TTL_DAYS=30

# Sessions
LOOM_SESSIONS_DIR=/root/.loom/sessions

# ─────────────────────────────────────────────────────────────────────────────
# LLM Providers
# ─────────────────────────────────────────────────────────────────────────────

GROQ_API_KEY=
NVIDIA_NIM_API_KEY=
DEEPSEEK_API_KEY=
GOOGLE_AI_KEY=
MOONSHOT_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

LLM_CASCADE_ORDER=groq,nvidia,deepseek,gemini,moonshot,openai,anthropic,vllm
LLM_DEFAULT_CHAT_MODEL=meta/llama-4-maverick-17b-128e-instruct
LLM_DEFAULT_EMBED_MODEL=nvidia/nv-embedqa-e5-v5
LLM_MAX_PARALLEL=12
LLM_DAILY_COST_CAP_USD=10.0

# ─────────────────────────────────────────────────────────────────────────────
# Search Providers
# ─────────────────────────────────────────────────────────────────────────────

EXA_API_KEY=
TAVILY_API_KEY=
FIRECRAWL_API_KEY=
BRAVE_API_KEY=
NEWS_API_KEY=
COINMARKETCAP_API_KEY=
INVESTING_API_KEY=

# UMMRO RAG endpoint (internal)
UMMRO_RAG_URL=http://ummro-rag:8000

# Default search provider
DEFAULT_SEARCH_PROVIDER=exa
DEFAULT_ACCEPT_LANGUAGE=en-US,en;q=0.9,ar;q=0.8

# ─────────────────────────────────────────────────────────────────────────────
# Infrastructure & Services
# ─────────────────────────────────────────────────────────────────────────────

# VastAI (GPU rental)
VASTAI_API_KEY=

# Stripe (Payment processing)
STRIPE_LIVE_KEY=
STRIPE_TEST_KEY=

# Email service
SMTP_USER=
SMTP_APP_PASSWORD=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Joplin (Note-taking)
JOPLIN_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────
# Tor & Dark Web (optional — disabled by default)
# ─────────────────────────────────────────────────────────────────────────────

TOR_ENABLED=false
TOR_SOCKS5_PROXY=127.0.0.1:9050
TOR_CONTROL_PORT=9051
TOR_CONTROL_PASSWORD=

# ─────────────────────────────────────────────────────────────────────────────
# Service-Specific Configuration (set by docker-compose, override if needed)
# ─────────────────────────────────────────────────────────────────────────────

# Core Service (fetch, search, deep, markdown)
LOOM_SERVICE=core
LOOM_HOST=0.0.0.0
LOOM_PORT=8787
LOOM_CONFIG_PATH=/etc/loom/core/config.json

# ─────────────────────────────────────────────────────────────────────────────
# Scraping Configuration
# ─────────────────────────────────────────────────────────────────────────────

SPIDER_CONCURRENCY=10
EXTERNAL_TIMEOUT_SECS=30
MAX_CHARS_HARD_CAP=200000
MAX_SPIDER_URLS=100

# Scrapling (built-in scraper)
SCRAPLING_RETRIES=3
SCRAPLING_TIMEOUT=30

# Firecrawl (optional if FIRECRAWL_API_KEY set)
FIRECRAWL_TIMEOUT=30

# ─────────────────────────────────────────────────────────────────────────────
# Research Pipeline Configuration
# ─────────────────────────────────────────────────────────────────────────────

RESEARCH_SEARCH_PROVIDERS=exa,brave
RESEARCH_EXPAND_QUERIES=true
RESEARCH_EXTRACT=true
RESEARCH_SYNTHESIZE=true
RESEARCH_EXTRACT_CONCURRENCY=3

# ─────────────────────────────────────────────────────────────────────────────
# Billing & Rate Limiting (loom-infra service)
# ─────────────────────────────────────────────────────────────────────────────

BILLING_ENABLED=true
RATE_LIMITING_ENABLED=true
RATE_LIMIT_PER_MINUTE=300
RATE_LIMIT_PER_HOUR=5000

# ─────────────────────────────────────────────────────────────────────────────
# Monitoring & Observability
# ─────────────────────────────────────────────────────────────────────────────

PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
JAEGER_ENABLED=false
JAEGER_ENDPOINT=http://jaeger:14268/api/traces

# ─────────────────────────────────────────────────────────────────────────────
# Security
# ─────────────────────────────────────────────────────────────────────────────

API_KEY_REQUIRED=true
API_KEY_HEADER=X-Loom-API-Key
CORS_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false

# ─────────────────────────────────────────────────────────────────────────────
# Feature Flags (enable/disable tool categories per service)
# ─────────────────────────────────────────────────────────────────────────────

# loom-core: always enabled
ENABLE_FETCH_TOOLS=true
ENABLE_SEARCH_TOOLS=true
ENABLE_MARKDOWN_TOOLS=true
ENABLE_SPIDER_TOOLS=true

# loom-redteam: AI safety & adversarial
ENABLE_REFRAME_TOOLS=true
ENABLE_SAFETY_TOOLS=true
ENABLE_ADVERSARIAL_TOOLS=true
ENABLE_CRESCENDO_TOOLS=true

# loom-intel: OSINT, dark web, threat intel, privacy
ENABLE_DARK_WEB_TOOLS=true
ENABLE_THREAT_INTEL_TOOLS=true
ENABLE_OSINT_TOOLS=true
ENABLE_PRIVACY_TOOLS=true
ENABLE_SOCIAL_GRAPH_TOOLS=true

# loom-infra: billing, auth, jobs, config
ENABLE_BILLING_TOOLS=true
ENABLE_AUTH_TOOLS=true
ENABLE_JOB_TOOLS=true
ENABLE_CONFIG_TOOLS=true
ENABLE_SESSION_TOOLS=true
ENABLE_MONITORING_TOOLS=true

# ─────────────────────────────────────────────────────────────────────────────
# Development & Debugging
# ─────────────────────────────────────────────────────────────────────────────

DEBUG_MODE=false
MOCK_EXTERNAL_SERVICES=false
SKIP_VALIDATION=false
