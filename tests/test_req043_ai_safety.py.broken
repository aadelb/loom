class TestAllToolsPresent:
    """Verify all 7 AI safety tools are importable and callable."""
    def (self):
        """Verify all 7 tools can be imported."""
        # This will fail at import if tools don't exist
        from loom.tools.ai_safety import (
            research_prompt_injection_test,
            research_model_fingerprint,
            research_bias_probe,
            research_safety_filter_map,
            research_compliance_check,
        )
        from loom.tools.ai_safety_extended import (
            research_hallucination_benchmark,
            research_adversarial_robustness,
        )

        assert callable(research_prompt_injection_test)
        assert callable(research_model_fingerprint)
        assert callable(research_bias_probe)
        assert callable(research_safety_filter_map)
        assert callable(research_compliance_check)
        assert callable(research_hallucination_benchmark)
        assert callable(research_adversarial_robustness)
    def (self):
        """Verify all tools accept target_url/domain parameters."""
        # These are all callable and accept URL parameters
        with patch("loom.tools.ai_safety.httpx.Client") as mock_client_class:
            mock_client = Mock()
            mock_client_class.return_value.__enter__.return_value = mock_client

            mock_response = Mock()
            mock_response.status_code = 200
            mock_response.text = "Response"
            mock_client.post.return_value = mock_response
            mock_client.get.return_value = mock_response

            # Each tool should accept URL parameter without error
            url = "http://example.com/api"

            research_prompt_injection_test(target_url=url)
            research_model_fingerprint(target_url=url)
            research_bias_probe(target_url=url)
            research_safety_filter_map(target_url=url)
            research_compliance_check(domain=url)

        research_hallucination_benchmark(target_url="http://example.com/api")

        with patch("loom.tools.ai_safety_extended.httpx.AsyncClient") as mock_async:
            mock_client = AsyncMock()
            mock_async.return_value.__aenter__.return_value = mock_client
            mock_response = AsyncMock()
            mock_response.status_code = 200
            mock_client.get.return_value = mock_response
            mock_client.post.return_value = mock_response

            research_adversarial_robustness(target_url="http://example.com/api")
