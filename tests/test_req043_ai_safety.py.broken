class TestComplianceCheck:
    """Test research_compliance_check returns compliance score."""
    def (self):
        """Verify tool returns compliance_score (float 0-100)."""
        with patch("loom.tools.ai_safety.httpx.Client") as mock_client_class:
            mock_client = Mock()
            mock_client_class.return_value.__enter__.return_value = mock_client

            mock_response = Mock()
            mock_response.status_code = 200
            mock_response.text = "Privacy policy: We collect data in compliance with GDPR"
            mock_client.get.return_value = mock_response

            result = research_compliance_check(
                domain="example.com",
                frameworks=["gdpr"],
            )

            assert "compliance_score" in result
            assert isinstance(result["compliance_score"], (int, float))
            assert 0 <= result["compliance_score"] <= 100
    def (self):
        """Verify tool returns frameworks_checked (list)."""
        with patch("loom.tools.ai_safety.httpx.Client") as mock_client_class:
            mock_client = Mock()
            mock_client_class.return_value.__enter__.return_value = mock_client

            mock_response = Mock()
            mock_response.status_code = 200
            mock_response.text = "Privacy policy"
            mock_client.get.return_value = mock_response

            result = research_compliance_check(
                domain="example.com",
                frameworks=["gdpr", "ccpa"],
            )

            assert "frameworks_checked" in result
            assert isinstance(result["frameworks_checked"], list)
    def (self):
        """Verify tool returns findings (list of requirement checks)."""
        with patch("loom.tools.ai_safety.httpx.Client") as mock_client_class:
            mock_client = Mock()
            mock_client_class.return_value.__enter__.return_value = mock_client

            mock_response = Mock()
            mock_response.status_code = 200
            mock_response.text = "Data protection"
            mock_client.get.return_value = mock_response

            result = research_compliance_check(
                domain="example.com",
            )

            assert "findings" in result
            assert isinstance(result["findings"], list)
    def (self):
        """Verify tool handles domain-only input (no http://)."""
        with patch("loom.tools.ai_safety.httpx.Client") as mock_client_class:
            mock_client = Mock()
            mock_client_class.return_value.__enter__.return_value = mock_client

            mock_response = Mock()
            mock_response.status_code = 200
            mock_response.text = "Data protection"
            mock_client.get.return_value = mock_response

            result = research_compliance_check(domain="example.com")

            # Should not error on domain-only input
            assert isinstance(result, dict)


