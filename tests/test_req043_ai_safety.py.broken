"""Test suite for REQ-043: AI Safety 7 tools return scores/risk levels.

Tests verify that all 7 AI safety tools return appropriate score/risk level fields:
1. research_prompt_injection_test — returns bypasses_detected (int)
2. research_model_fingerprint — returns confidence (float 0-1)
3. research_bias_probe — returns bias_scores (dict of floats 0-1)
4. research_safety_filter_map — returns filter_map (dict of thresholds)
5. research_compliance_check — returns compliance_score (float 0-100)
6. research_hallucination_benchmark — returns accuracy_rate (float 0-1)
7. research_adversarial_robustness — returns robustness_score (float 0-1)
"""

import pytest
from unittest.mock import Mock, patch, AsyncMock
from loom.tools.ai_safety import (
    research_prompt_injection_test,
    research_model_fingerprint,
    research_bias_probe,
    research_safety_filter_map,
    research_compliance_check,
)
from loom.tools.ai_safety_extended import (
    research_hallucination_benchmark,
    research_adversarial_robustness,
)


pytestmark = pytest.mark.asyncio

class TestPromptInjectionTest:
    """Test research_prompt_injection_test returns bypass detection score."""
    def (self):
        """Verify tool returns bypasses_detected (int) field."""
        with patch("loom.tools.ai_safety.httpx.Client") as mock_client_class:
            mock_client = Mock()
            mock_client_class.return_value.__enter__.return_value = mock_client

            # Mock response for a test vector
            mock_response = Mock()
            mock_response.text = "I cannot help with that"
            mock_response.status_code = 200
            mock_client.post.return_value = mock_response

            result = research_prompt_injection_test(
                target_url="http://example.com/api",
                model_name="test-model",
                test_count=1,
            )

            assert "bypasses_detected" in result
            assert isinstance(result["bypasses_detected"], int)
            assert result["bypasses_detected"] >= 0
    def (self):
        """Verify tool returns tests_run (int) field."""
        with patch("loom.tools.ai_safety.httpx.Client") as mock_client_class:
            mock_client = Mock()
            mock_client_class.return_value.__enter__.return_value = mock_client

            mock_response = Mock()
            mock_response.text = "I cannot help with that"
            mock_response.status_code = 200
            mock_client.post.return_value = mock_response

            result = research_prompt_injection_test(
                target_url="http://example.com/api",
                model_name="test-model",
                test_count=3,
            )

            assert "tests_run" in result
            assert isinstance(result["tests_run"], int)
            assert result["tests_run"] > 0
    def (self):
        """Verify tool handles invalid URL and returns error."""
        result = research_prompt_injection_test(
            target_url="not-a-valid-url",
            model_name="test-model",
        )

        assert "error" in result
        # But the tool should still be a dict
        assert isinstance(result, dict)


class TestModelFingerprint:
    """Test research_model_fingerprint returns confidence score."""
    def (self):
        """Verify tool returns confidence (float 0-1) field."""
        with patch("loom.tools.ai_safety.httpx.Client") as mock_client_class:
            mock_client = Mock()
            mock_client_class.return_value.__enter__.return_value = mock_client

            mock_response = Mock()
            mock_response.text = "This is a helpful response."
            mock_response.status_code = 200
            mock_client.post.return_value = mock_response

            result = research_model_fingerprint(
                target_url="http://example.com/api",
                probes=1,
            )

            assert "confidence" in result
            assert isinstance(result["confidence"], float)
            assert 0.0 <= result["confidence"] <= 1.0
    def (self):
        """Verify tool returns likely_model (str) field."""
        with patch("loom.tools.ai_safety.httpx.Client") as mock_client_class:
            mock_client = Mock()
            mock_client_class.return_value.__enter__.return_value = mock_client

            mock_response = Mock()
            mock_response.text = "This is a response."
            mock_response.status_code = 200
            mock_client.post.return_value = mock_response

            result = research_model_fingerprint(
                target_url="http://example.com/api",
                probes=2,
            )

            assert "likely_model" in result
            assert isinstance(result["likely_model"], str)
    def (self):
        """Verify tool handles invalid URL gracefully."""
        result = research_model_fingerprint(
            target_url="invalid-url-format",
        )

        assert "error" in result
        assert isinstance(result, dict)


class TestBiasProbe:
    """Test research_bias_probe returns bias scores."""
    def (self):
        """Verify tool returns bias_scores (dict of floats 0-1)."""
        with patch("loom.tools.ai_safety.httpx.Client") as mock_client_class:
            mock_client = Mock()
            mock_client_class.return_value.__enter__.return_value = mock_client

            mock_response = Mock()
            mock_response.text = "This is a neutral response."
            mock_response.status_code = 200
            mock_client.post.return_value = mock_response

            result = research_bias_probe(
                target_url="http://example.com/api",
                categories=["gender"],
            )

            assert "bias_scores" in result
            assert isinstance(result["bias_scores"], dict)
            for score in result["bias_scores"].values():
                assert isinstance(score, float)
                assert 0.0 <= score <= 1.0
    def (self):
        """Verify tool returns bias_detected (bool)."""
        with patch("loom.tools.ai_safety.httpx.Client") as mock_client_class:
            mock_client = Mock()
            mock_client_class.return_value.__enter__.return_value = mock_client

            mock_response = Mock()
            mock_response.text = "Response"
            mock_response.status_code = 200
            mock_client.post.return_value = mock_response

            result = research_bias_probe(
                target_url="http://example.com/api",
            )

            assert "bias_detected" in result
            assert isinstance(result["bias_detected"], bool)
    def (self):
        """Verify tool returns categories_tested (list)."""
        with patch("loom.tools.ai_safety.httpx.Client") as mock_client_class:
            mock_client = Mock()
            mock_client_class.return_value.__enter__.return_value = mock_client

            mock_response = Mock()
            mock_response.text = "Response"
            mock_response.status_code = 200
            mock_client.post.return_value = mock_response

            result = research_bias_probe(
                target_url="http://example.com/api",
                categories=["gender", "age"],
            )

            assert "categories_tested" in result
            assert isinstance(result["categories_tested"], list)


